# Local Terraform state - contains sensitive data, never commit
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Variable files may contain secrets
*.tfvars
*.tfvars.json

# Backend config contains storage account access key
backend.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
