PORT=3001

# Bcrypt Configuration (REQUIRED)
# Recommended: 12 (good balance of security and performance)
BCRYPT_SALT_ROUNDS=12

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

DB_USER=<your_pg_username>
DB_PASSWORD=<your_pg_password>
DB_HOST=localhost
DB_PORT=<your_pg_port>

DB_NAME=kainos-jobs
DB_SCHEMA=public

# JWT Configuration
JWT_SECRET="your-secret-key-here-use-openssl-rand-base64-32"
# JWT_EXPIRES_IN is optional (defaults to 24h)
JWT_EXPIRES_IN="24h"

# Bcrypt Configuration (REQUIRED)
BCRYPT_SALT_ROUNDS=12

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# Feature Toggles
ENABLE_JOB_APPLICATIONS=true
ENABLE_ADD_JOB_ROLE=true